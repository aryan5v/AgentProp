{
  "name": "ml_core",
  "description": "Dependency-light AgentProp ML/RL quality suite inspired by ml-intern-style reproducible recipes.",
  "runtime": {
    "kind": "local",
    "requires_gpu": false,
    "env": {
      "optional": [
        "MODAL_TOKEN_ID",
        "MODAL_TOKEN_SECRET",
        "TOKEN_ROUTER_API_KEY"
      ],
      "required": []
    }
  },
  "artifacts": {
    "root": "results/ml_core",
    "save_traces": true,
    "private_by_default": true
  },
  "runs": [
    {
      "id": "ml_seed_scorer_checkpoint",
      "module": "experiments.train_seed_scorer",
      "args": {
        "--model": "mlp",
        "--task": "seed",
        "--budget": 2,
        "--trials": 10,
        "--epochs": 40,
        "--allow-heuristic-labels": true,
        "--out": "{artifact_root}/models/mlp_seed_scorer_metrics.json",
        "--registry-root": "{artifact_root}/model_registry",
        "--run-id": "mlp_seed_scorer"
      }
    },
    {
      "id": "ml_edge_pruning_checkpoint",
      "module": "experiments.train_edge_pruning_scorer",
      "args": {
        "--fraction": 0.2,
        "--epochs": 40,
        "--out": "{artifact_root}/models/edge_pruning_metrics.json",
        "--registry-root": "{artifact_root}/model_registry",
        "--run-id": "edge_pruning_scorer"
      }
    },
    {
      "id": "ml_generalization_mlp",
      "module": "experiments.evaluate_ml_generalization",
      "args": {
        "--model": "mlp",
        "--budget": 2,
        "--trials": 10,
        "--epochs": 40,
        "--out": "{artifact_root}/generalization_mlp.json"
      }
    },
    {
      "id": "routing_baselines",
      "module": "experiments.evaluate_routing_baselines",
      "args": {
        "--workflows": "chain,star,tree,generic_dag,layered_pipeline",
        "--budget": 2,
        "--trials": 10,
        "--episodes": 20,
        "--epochs": 20,
        "--max-steps": 8,
        "--out": "{artifact_root}/routing_baselines.json"
      }
    },
    {
      "id": "rl_policy_ppo",
      "module": "experiments.run_rl_routing",
      "args": {
        "--policy": "ppo",
        "--trials": 10,
        "--episodes": 20,
        "--max-steps": 8,
        "--out": "{artifact_root}/rl_ppo_trajectories.json",
        "--registry-root": "{artifact_root}/model_registry",
        "--run-id": "ppo_routing_policy"
      }
    },
    {
      "id": "rl_policy_feature",
      "module": "experiments.run_rl_routing",
      "args": {
        "--policy": "feature-policy",
        "--trials": 10,
        "--episodes": 20,
        "--max-steps": 8,
        "--out": "{artifact_root}/rl_feature_policy_trajectories.json",
        "--registry-root": "{artifact_root}/model_registry",
        "--run-id": "feature_policy_routing"
      }
    }
  ]
}
