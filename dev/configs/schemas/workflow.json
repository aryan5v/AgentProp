{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aryan5v/AgentProp/dev/configs/schemas/workflow.json",
  "title": "AgentProp Workflow",
  "description": "Directed weighted graph for multi-agent workflow analysis.",
  "type": "object",
  "required": ["nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "AGENT",
            "TOOL",
            "MEMORY",
            "DOCUMENT",
            "VERIFIER",
            "PLANNER",
            "EXECUTOR",
            "REVIEWER",
            "OUTPUT",
            "CUSTOM"
          ]
        },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "token_cost": { "type": "number", "minimum": 0 },
        "latency": { "type": "number", "minimum": 0 },
        "reliability": { "type": "number", "minimum": 0, "maximum": 1 },
        "error_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "context_capacity": { "type": ["integer", "null"], "minimum": 0 },
        "tool_access": { "type": "array", "items": { "type": "string" } },
        "importance_score": { "type": ["number", "null"] },
        "metadata": { "type": "object" }
      }
    },
    "edge": {
      "type": "object",
      "required": ["source", "target"],
      "additionalProperties": true,
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "message_cost": { "type": "number", "minimum": 0 },
        "latency": { "type": "number", "minimum": 0 },
        "relevance": { "type": "number", "minimum": 0, "maximum": 1 },
        "reliability": { "type": "number", "minimum": 0, "maximum": 1 },
        "activation_probability": { "type": "number", "minimum": 0, "maximum": 1 },
        "dependency_strength": { "type": "number", "minimum": 0, "maximum": 1 },
        "weight": { "type": "number", "minimum": 0 },
        "metadata": { "type": "object" }
      }
    }
  }
}
